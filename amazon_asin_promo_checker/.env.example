## Amazon Product Advertising API (PA-API) credentials
##
## Copy this file to `.env` and fill in values.
## `.env` is ignored by git (secrets).
##
## Required for PA API mode:
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=

## Optional overrides (usually leave as-is)
# PAAPI_MARKETPLACE=www.amazon.com
# PAAPI_REGION=us-east-1
# PAAPI_HOST=webservices.amazon.com
# PAAPI_URI=/paapi5/getitems
