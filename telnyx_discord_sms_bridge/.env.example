# Required
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+15419202540
DISCORD_WEBHOOK_URL=
BRIDGE_API_KEY=

# Optional comma-separated extra sender numbers (also see config/settings.json)
TELNYX_FROM_NUMBERS=+18334882119

# Server
APP_HOST=0.0.0.0
APP_PORT=8787
CONFIG_PATH=config/settings.json
LOG_LEVEL=INFO

# Optional Telnyx settings
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PUBLIC_KEY=
TELNYX_REQUIRE_SIGNATURE=false
# Telnyx portal public keys are usually base64. Set REQUIRE_SIGNATURE=true in production.

# Optional Telnyx API override
TELNYX_API_BASE=https://api.telnyx.com/v2
