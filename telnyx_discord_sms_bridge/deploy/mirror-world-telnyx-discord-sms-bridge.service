[Unit]
Description=Mirror World - Telnyx Discord SMS Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rsadmin
WorkingDirectory=/home/rsadmin/bots/mirror-world/telnyx_discord_sms_bridge
ExecStart=/home/rsadmin/bots/mirror-world/telnyx_discord_sms_bridge/.venv/bin/python -m app.main
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
