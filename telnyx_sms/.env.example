# Telnyx API key (required)
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender number (optional: auto-fetched from Telnyx if missing)
# FROM_NUMBER=+15551234567

# Optional defaults (can override via batch prompts)
# DEFAULT_MESSAGE=Test message from Telnyx API
# TO_NUMBER=+15559876543

# Webhook server port for inbound SMS (default 8765)
# TELNYX_WEBHOOK_PORT=8765
