# Ignore everything by default (python-only RS bots repo)
*

# Allow this ignore file itself
!/.gitignore

# Allow helper scripts at repo root
!/push_rsbots_py_only.bat
!/oracle_baseline_check.bat
!/push_mwbots_py_only.bat
!/oracle_tools_menu_mwbots.bat
!/oracle_baseline_check_mwbots.bat
!/kill_git_ssh_tasks.bat
!/oracle_server_specs_menu.bat
!/update_rs_bots.bat

# Allow canonical docs at repo root
!/CANONICAL_RULES.md

# Allow shared utilities
!shared/
!shared/**/
!shared/*.py
!shared/**/*.py

# Allow non-secret Oracle server list (keys remain untracked)
!oraclekeys/
!oraclekeys/servers.json

# Local Oracle SSH keys folder (override blanket * so Cursor/git see files here).
# Still override **/*.key below so keys are not globally ignored under this path.
!oracleserverkeys/
!oracleserverkeys/**

# Only allow python from the RS bot folders
!RSAdminBot/
!RSAdminBot/**/
!RSAdminBot/*.py
!RSAdminBot/**/*.py
!RSAdminBot/*.sh
!RSAdminBot/**/*.sh
!RSAdminBot/COMMANDS.md
!RSAdminBot/config.json
!RSAdminBot/config.secrets.example.json
!RSAdminBot/messages.json
!RSAdminBot/vouch_config.json
!RSAdminBot/RSNotes/configs.json

!RSCheckerbot/
!RSCheckerbot/**/
!RSCheckerbot/*.py
!RSCheckerbot/**/*.py
!RSCheckerbot/COMMANDS.md
!RSCheckerbot/config.json
!RSCheckerbot/messages.json
!RSCheckerbot/vouch_config.json

!RSForwarder/
!RSForwarder/**/
!RSForwarder/*.py
!RSForwarder/**/*.py
!RSForwarder/COMMANDS.md
!RSForwarder/config.json
!RSForwarder/rs_fs_manual_overrides.json
!RSForwarder/messages.json
!RSForwarder/vouch_config.json

!RSMentionPinger/
!RSMentionPinger/**/
!RSMentionPinger/*.py
!RSMentionPinger/**/*.py
!RSMentionPinger/COMMANDS.md
!RSMentionPinger/config.json
!RSMentionPinger/messages.json
!RSMentionPinger/vouch_config.json

!RSOnboarding/
!RSOnboarding/**/
!RSOnboarding/*.py
!RSOnboarding/**/*.py
!RSOnboarding/COMMANDS.md
!RSOnboarding/config.json
!RSOnboarding/messages.json
!RSOnboarding/vouch_config.json

!RSuccessBot/
!RSuccessBot/**/
!RSuccessBot/*.py
!RSuccessBot/**/*.py
!RSuccessBot/COMMANDS.md
!RSuccessBot/config.json
!RSuccessBot/messages.json
!RSuccessBot/vouch_config.json

!RSPromoBot/
!RSPromoBot/**/
!RSPromoBot/*.py
!RSPromoBot/**/*.py
!RSPromoBot/COMMANDS.md
!RSPromoBot/config.json
!RSPromoBot/config.json.example
!RSPromoBot/messages.json
!RSPromoBot/README.md
!RSPromoBot/requirements.txt

!RSCashoutBot/
!RSCashoutBot/**/
!RSCashoutBot/*.py
!RSCashoutBot/**/*.py
!RSCashoutBot/COMMANDS.md
!RSCashoutBot/README.md
!RSCashoutBot/messages.json
!RSCashoutBot/config.example.json
!RSCashoutBot/requirements.txt
!RSCashoutBot/google_apps_script_example.js

# WhopMembershipSync service (lives in this repo; deployed to Oracle)
!WhopMembershipSync/
!WhopMembershipSync/**/
!WhopMembershipSync/*.py
!WhopMembershipSync/**/*.py
!WhopMembershipSync/*.md
!WhopMembershipSync/**/*.md
!WhopMembershipSync/config.json
!WhopMembershipSync/requirements.txt
!WhopMembershipSync/*.bat

# Allow shared scripts used by RSAdminBot (Oracle data tools)
!scripts/
!scripts/**/
!scripts/*.py
!scripts/**/*.py

# Mavelytest (Instore flow tester, Mavely helpers; no secrets here)
!Mavelytest/
!Mavelytest/**/
!Mavelytest/*.py
!Mavelytest/**/*.py
!Mavelytest/*.bat
Mavelytest/audit_logs/
Mavelytest/*_report.json

# Kit (GHL and other integration tools)
!kit/
!kit/**/
!kit/*.py
!kit/**/*.py
!kit/*.bat
!kit/ghl_token.example.txt
kit/ghl_token.txt
kit/*.csv

# Allow systemd unit templates (used for deployment)
!systemd/
!systemd/**/
!systemd/*.service

# Telnyx SMS sender
!telnyx_sms/
!telnyx_sms/**/
!telnyx_sms/*.py
!telnyx_sms/*.bat
!telnyx_sms/*.txt
!telnyx_sms/.env.example
telnyx_sms/sent_ids.json
telnyx_sms/inbound.json

# Explicitly keep legacy/original sources out of GitHub
RSAdminBot/original_files/**

# Never include local server snapshots
Oraclserver-files/**
Oraclserver-files-mwbots/**

# Never include downloaded runtime data (may contain PII; analysis-only)
OracleServerData/**

# Secrets / local-only scratchpads (do not commit)
rs-bot-tokens.txt
*.env
.tmp/
**/__pycache__/
**/*.pyc

# Mavely local auth artifacts (never commit)
RSForwarder/mavely_cookies*.txt
RSForwarder/mavely_refresh_token*.txt
RSForwarder/.mavely_profile/**
MWBots/Instorebotforwarder/mavely_cookies*.txt
MWBots/Instorebotforwarder/mavely_refresh_token*.txt
MWBots/Instorebotforwarder/mavely_auth_token*.txt
MWBots/Instorebotforwarder/mavely_id_token*.txt

# Playwright persistent browser profile (never commit)
MWBots/Instorebotforwarder/playwright_profile/**
MWBots/Instorebotforwarder/.playwright/**

# Instorebotforwarder single-instance lock (runtime artifact)
MWBots/Instorebotforwarder/.instorebotforwarder.lock

# Virtualenvs
.venv/
venv/

# Server-only secrets (never commit)
**/config.secrets.json

# SSH private keys
**/*.key
**/*.pem
**/*.ppk

# Local token scratchpads (never commit / never deploy)
**/rs-bot-tokens.txt

# Runtime DB/data files (server-owned)
**/*.db
**/*.sqlite
**/*.sqlite3

# RS bot runtime JSON (server-owned; never commit / never deploy)
RSCheckerbot/queue.json
RSCheckerbot/registry.json
RSCheckerbot/invites.json
RSCheckerbot/member_history.json
RSCheckerbot/staff_alerts.json
RSCheckerbot/payment_cache.json
RSCheckerbot/whop_discord_link.json
RSCheckerbot/whop_identity_cache.json
RSCheckerbot/whop_native_membership_cache.json
RSCheckerbot/whop_webhook_raw_payloads.json
RSCheckerbot/trial_history.json
RSCheckerbot/reporting_store.json

RSOnboarding/tickets.json
RSOnboarding/completion_sent.json

# RSPromoBot runtime (server-owned)
RSPromoBot/data/
RSPromoBot/logs/

# RSCashoutBot secrets + runtime (never commit)
RSCashoutBot/config.json
RSCashoutBot/tickets.json
RSCashoutBot/bot.log
